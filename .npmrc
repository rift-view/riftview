# Use a flat node_modules layout instead of pnpm's default isolated
# (.pnpm-virtual-store) layout. The trade-off is intentional and
# specific to this repo's packaging story:
#
# Why hoisted: electron-builder's app-builder traverses
# apps/desktop/node_modules to walk the full transitive dep tree
# when packing app.asar. With pnpm's isolated layout, sibling
# transitive deps live at .pnpm/<name>@<ver>/node_modules/<sibling>
# and are only discoverable via Node's runtime resolver — not via
# the static directory walks app-builder relies on. The result
# under isolated mode is silent transitive-dep loss in the asar
# (e.g., ms went missing because debug's siblings weren't packed),
# which manifests as a hung main process at boot. Hoisted layout
# replicates the npm-style flat tree app-builder expects.
#
# What we keep from pnpm:
#  - pnpm-lock.yaml (deterministic, smaller than package-lock.json,
#    fully understood by Renovate)
#  - packageManager corepack-style pin in package.json
#  - pnpm.onlyBuiltDependencies allow-list (supply-chain firewall)
#  - pnpm.overrides for vite version pinning
#  - workspace:* protocol resolution
#
# What we trade away: pnpm's strict per-package phantom-dep
# detection at install time. Acceptable because (a) the published-
# tarball-shape phantom-dep guard in CI still runs `pnpm pack` +
# isolated install, which catches the exact phantom class that
# motivated RIFT-69/-70 (commit 7f50643 fallout); (b) typecheck
# would have caught @types/ini-style cross-workspace phantoms even
# under hoisted mode; (c) the lockfile-change guard ensures only
# Renovate/Dependabot mutates the dep graph, so drift is minimal.
node-linker=hoisted

# `pnpm deploy --filter @riftview/desktop ./apps/desktop/deploy` runs as
# a packaging step before electron-builder (see apps/desktop scripts).
# pnpm 10 requires either `inject-workspace-packages=true` or the
# `--legacy` flag to deploy a workspace; injection is the documented
# forward path. With this on, the workspace:* deps on @riftview/cloud-scan
# and @riftview/shared are packed into the deploy tree as bundled
# tarballs (rather than symlinks), so the resulting deploy/ is fully
# self-contained — exactly what electron-builder expects.
inject-workspace-packages=true
