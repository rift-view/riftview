{
  "name": "riftview-monorepo",
  "private": true,
  "version": "0.2.0",
  "description": "RiftView monorepo — desktop, CLI, and shared analysis library",
  "packageManager": "pnpm@10.33.1+sha512.05ba3c1d5d1c18f68df06470d74055e62d41fc110a0c660db1b2dfb2785327f04cf0f68345d4609bc52089e7fa0343c31593b2f9594e2c5d5da426230acc9820",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:integration": "vitest run --config apps/cli/vitest.integration.config.ts",
    "test:e2e": "cd apps/desktop && npx playwright test --grep-invert @release",
    "test:e2e:release": "cd apps/desktop && RIFTVIEW_BUILT_APP=1 npx playwright test --grep @release",
    "test:e2e:release:mac": "cd apps/desktop && RIFTVIEW_BUILT_APP=1 npx playwright test --grep @release-mac",
    "localstack:up": "docker compose -f .localstack/compose.yml up -d && ./scripts/wait-localstack.sh && cd apps/cli/tests/integration/fixtures && terraform init -input=false && terraform apply -auto-approve",
    "localstack:down": "docker compose -f .localstack/compose.yml down -v",
    "build": "pnpm -r --if-present run build",
    "build:cli": "pnpm --filter @riftview/cli run build",
    "cli": "tsx apps/cli/cli/bin.ts",
    "dev": "pnpm --filter @riftview/desktop run dev",
    "start": "pnpm --filter @riftview/desktop run start",
    "stories": "pnpm --filter @riftview/desktop run stories"
  },
  "pnpm": {
    "overrides": {
      "vite": "^7.2.6"
    },
    "onlyBuiltDependencies": [
      "@swc/core",
      "better-sqlite3",
      "electron",
      "esbuild",
      "lefthook",
      "msw",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.19.1",
    "@vitest/ui": "^4.0.18",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "lefthook": "^2.1.6",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
