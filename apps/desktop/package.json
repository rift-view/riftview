{
  "name": "@riftview/desktop",
  "version": "0.2.0",
  "private": true,
  "description": "RiftView desktop (Electron)",
  "main": "./out/main/index.js",
  "author": "RiftView",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "pnpm run typecheck && electron-vite build",
    "deploy": "rm -rf deploy && pnpm --filter @riftview/desktop --prod deploy ./deploy",
    "rebuild": "cd deploy && pnpm exec electron-builder install-app-deps",
    "build:unpack": "pnpm run build && pnpm run deploy && pnpm run rebuild && cd deploy && pnpm exec electron-builder --dir",
    "build:win": "electron-vite build && pnpm run deploy && pnpm run rebuild && cd deploy && pnpm exec electron-builder --win",
    "build:mac": "electron-vite build && pnpm run deploy && pnpm run rebuild && cd deploy && pnpm exec electron-builder --mac",
    "build:linux": "electron-vite build && pnpm run deploy && pnpm run rebuild && cd deploy && pnpm exec electron-builder --linux",
    "test": "vitest run",
    "test:watch": "vitest",
    "stories": "ladle serve"
  },
  "dependencies": {
    "@aws-sdk/client-cloudfront": "^3.1011.0",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@fontsource-variable/libre-franklin": "^5.2.8",
    "@fontsource/archivo-narrow": "^5.2.8",
    "@fontsource/fragment-mono": "^5.2.8",
    "@riftview/cloud-scan": "workspace:*",
    "@riftview/shared": "workspace:*",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.10.1",
    "better-sqlite3": "^12.9.0",
    "electron-updater": "^6.3.9",
    "html-to-image": "^1.11.13",
    "ini": "^6.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@ladle/react": "^5.1.1",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/ini": "^4.1.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "electron": "39.8.8",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.8",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "^4.2.1",
    "vite": "^7.2.6"
  }
}
