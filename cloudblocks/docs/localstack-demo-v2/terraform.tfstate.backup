            "output_sha512": "3510cc50c127b782dc9f336b1fa6e24056ad4b2ef55c6c2087de9359c390c9dd1c2ed1b2fe7d054672d77c89b08bd7b2806e30f67c21bc364777c05f64832dea",
            "output_size": 479,
            "source": [
              {
                "content": "import json, os, boto3\n\n_endpoint = os.environ.get('AWS_ENDPOINT_URL', 'http://localhost.localstack.cloud:4566')\n_region   = os.environ.get('AWS_REGION', 'us-east-1')\n\ndynamo = boto3.resource('dynamodb', region_name=_region, endpoint_url=_endpoint)\ntable  = dynamo.Table(os.environ.get('TABLE_NAME', 'demo-items'))\n\ndef handler(event, _ctx):\n    for record in event.get('Records', []):\n        body = json.loads(record.get('body', '{}'))\n        print(f\"Processing workflow event: {body}\")\n    return {'statusCode': 200}\n",
                "filename": "handler.py"
              }
            ],
            "source_content": null,
            "source_content_filename": null,
            "source_dir": null,
            "source_file": null,
            "type": "zip"
          },
