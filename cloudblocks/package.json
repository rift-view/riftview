{
  "name": "cloudblocks",
  "version": "0.9.0",
  "description": "Visual AWS infrastructure management desktop app",
  "main": "./out/main/index.js",
  "author": "cloudblocks",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@aws-sdk/client-acm": "^3.1011.0",
    "@aws-sdk/client-apigatewayv2": "^3.1011.0",
    "@aws-sdk/client-cloudfront": "^3.1011.0",
    "@aws-sdk/client-dynamodb": "^3.1012.0",
    "@aws-sdk/client-ec2": "^3.1007.0",
    "@aws-sdk/client-ecr": "^3.1012.0",
    "@aws-sdk/client-elastic-load-balancing-v2": "^3.1007.0",
    "@aws-sdk/client-eventbridge": "^3.1012.0",
    "@aws-sdk/client-lambda": "^3.1007.0",
    "@aws-sdk/client-rds": "^3.1007.0",
    "@aws-sdk/client-route-53": "^3.1012.0",
    "@aws-sdk/client-s3": "^3.1007.0",
    "@aws-sdk/client-secrets-manager": "^3.1012.0",
    "@aws-sdk/client-sfn": "^3.1012.0",
    "@aws-sdk/client-sns": "^3.1012.0",
    "@aws-sdk/client-sqs": "^3.1012.0",
    "@aws-sdk/client-ssm": "^3.1012.0",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@xyflow/react": "^12.10.1",
    "electron-updater": "^6.3.9",
    "ini": "^6.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/ini": "^4.1.1",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.27",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.8",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.0.18"
  }
}
